# ═══════════════════════════════════════════════════════════════════
# GasSafer — environment configuration
# Copy to .env in project root:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Mobile app (Expo) ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Backend server ────────────────────────────────────────────────
PORT=3000
SERVER_PUBLIC_URL=http://localhost:3000

# Firebase Admin (backend) — use file path OR inline JSON for cloud deploy
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Gas alert threshold — match THRESHOLD in firmware config.h (v2.1 default: 680)
GAS_THRESHOLD=680

# Post-notification escalation (repeat voice/SMS if no ack)
ALERT_ESCALATION_MS=180000
ALERT_MAX_ESCALATIONS=5
HISTORY_LOG_MS=30000

# Optional: require this key on POST /api/sensor (NodeMCU backend mode)
SENSOR_API_KEY=

# Firebase: REST mode avoids OAuth SSL errors on some networks (default)
# FIREBASE_USE_ADMIN=true
# FIREBASE_IGNORE_SSL=true

# ── Twilio (voice + SMS alerts) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
TWILIO_PHONE_TO=

# ── Africa's Talking (USSD) ───────────────────────────────────────
# Sign up: https://account.africastalking.com
# Create USSD channel → Callback URL: https://YOUR-PUBLIC-URL/ussd
# Update USSD_CODE in constants/index.ts to the live Africa's Talking code
AT_USERNAME=sandbox
AT_API_KEY=
