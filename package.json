{
  "name": "gassafer-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "GasSafer — IoT gas leak monitoring (Expo mobile + Node.js backend + NodeMCU)",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "mobile": "expo start",
    "mobile:android": "expo start --android",
    "mobile:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "backend": "npm run dev --prefix backend",
    "backend:start": "npm start --prefix backend",
    "backend:simulate": "npm run simulate --prefix backend",
    "install:all": "npm install --legacy-peer-deps && npm install --prefix backend"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "axios": "^1.7.0",
    "babel-preset-expo": "~54.0.10",
    "dotenv": "^17.4.2",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^10.14.1",
    "firebase-admin": "^14.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
