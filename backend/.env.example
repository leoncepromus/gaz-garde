# GasSafer backend — set these in Render Dashboard → Environment
# Render callback base URL: https://gaz-garde.onrender.com
# Africa's Talking USSD callback: https://gaz-garde.onrender.com/ussd
# (Local dev: copy values from project root .env)

PORT=10000
SERVER_PUBLIC_URL=https://gaz-garde.onrender.com

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com

GAS_THRESHOLD=680
FIREBASE_POLL_MS=3000
ALERT_ESCALATION_MS=180000
ALERT_MAX_ESCALATIONS=5

# Firebase Admin mode (recommended to avoid REST 401 auth errors)
FIREBASE_USE_ADMIN=true
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
TWILIO_PHONE_TO=

AT_USERNAME=sandbox
AT_API_KEY=

# USSD resource assigned by Africa's Talking
USSD_CODE=*801*1560#

# Optional — protect POST /api/sensor from NodeMCU
SENSOR_API_KEY=
